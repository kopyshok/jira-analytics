# Application
APP_NAME=Jira Analytics
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=sqlite:///./data/jira_analytics.db

# Jira Cloud credentials
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token

# Paths
DATA_DIR=./data
EXPORTS_DIR=./exports
