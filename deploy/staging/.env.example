# =============================================================================
# STAGING ENVIRONMENT — copy to .env, fill ALL values, chmod 600 .env
# Staging runs on HTTP port 8080. Do NOT use production secrets here.
# =============================================================================

# --- Deployment ---
APP_VERSION=v1.0.0
GHCR_ORG=akim4ik

# --- Database password (different from prod!) ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(24))"
DB_PASSWORD=

# --- App runtime ---
DEBUG=false
LOG_LEVEL=INFO
TZ=Europe/Moscow

# --- CORS: staging is served over HTTP on port 8080 ---
# Example: http://192.168.1.100:8080  or  http://jira-staging.company.local:8080
CORS_ORIGINS=

# --- Authentication (different keys from prod!) ---
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=
JWT_EXPIRE_HOURS=8
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# --- Initial admin (remove ADMIN_PASSWORD after first login) ---
ADMIN_EMAIL=admin@company.ru
ADMIN_PASSWORD=

# --- LLM API keys (can reuse prod keys or leave blank) ---
GEMINI_API_KEY=
OPENROUTER_API_KEY=
